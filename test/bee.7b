# build the simple tzip crate - https://github.com/lovasoa/tinyzip
crate  =tzip
crate main=lib
dep_crates=[]
comp opts=[--cfg,feature="std"]
crate_src=src
test file=test
common =..${~/~}..${~/~}simscript${~/~}comm-crate.7b:file
common_test =..${~/~}..${~/~}simscript${~/~}comm-test.7b:file
crate_dir=..${~/~}..${~/~}crates
doc_dir=..${~/~}..${~/~}docs

version=1.00a(004)
set_env(VERSION,version)

include(common);
include(common_test);